{
  "expo": {
    "name": "landed",
    "slug": "landed",
    "version": "1.0.0",
    "web": {
      "favicon": "./src/assets/favicon.png"
    },

    "scheme": "landed",
    "experiments": {
      "tsconfigPaths": true
    },

    "plugins": ["expo-router"],

    "orientation": "portrait",
    "icon": "./src/assets/icon.png",

    "userInterfaceStyle": "light",

    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.landed"
    }
  }
}
